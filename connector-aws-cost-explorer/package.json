    "@aws-sdk/client-cost-optimization-hub": "3.1002.0",
    "@aws-sdk/client-organizations": "3.1002.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "catalog:"
  }
}
